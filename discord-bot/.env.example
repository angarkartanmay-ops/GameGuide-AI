# ═══════════════════════════════════════════════════════════════════════════
#  GameGuide-AI Discord Bot — environment variables
#  ───────────────────────────────────────────────────────────────────────
#  Copy to .env and fill in the values:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ─── REQUIRED ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=                # Bot token → https://discord.com/developers/applications → Bot tab → Reset Token
DISCORD_CLIENT_ID=            # Application ID (same page, "General Information")
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=            # Supabase → Project Settings → API → "anon public"

# ─── STRONGLY RECOMMENDED ──────────────────────────────────────────────────
# Without this, chat history persistence is disabled (RLS blocks anon writes).
SUPABASE_SERVICE_ROLE_KEY=    # Supabase → Project Settings → API → "service_role" (KEEP SECRET)

# Optional dev shortcut for `npm run register:guild`
DISCORD_GUILD_ID=

# ─── 24/7 HEALTH + KEEP-ALIVE (set ONE of these per platform) ──────────────
# All free hosts: keep the bot's HTTP server bound to this port. Most hosts
# inject PORT automatically; this is the fallback.
PORT=3000

# Self-ping URL — required for hosts that sleep idle services
# (Render free, Replit, Cyclic). Set this to your bot's public URL
# WITHOUT trailing slash. The bot will GET <URL>/ping every 4 min.
#   Render:  https://gameguide-bot.onrender.com
#   Replit:  https://gameguide-bot.<user>.repl.co
#   Koyeb:   https://gameguide-bot-<user>.koyeb.app
# Leave blank if you're on Fly.io / Railway / a VPS (no idle-sleep).
KEEPALIVE_URL=

# Override default 4-minute ping interval (ms). Most free tiers sleep at 15 min idle.
KEEPALIVE_INTERVAL_MS=240000

# ─── PREMIUM / MONETIZATION (all optional) ─────────────────────────────────
# Manual premium overrides — comma-separated Discord IDs
PREMIUM_USER_IDS=
PREMIUM_GUILD_IDS=

# Upgrade buttons surfaced in /premium
STRIPE_PAYMENT_LINK=
PATREON_URL=
KOFI_URL=

# Top.gg vote rewards (12h Pro tier per vote)
TOPGG_VOTE_URL=                  # https://top.gg/bot/<your_bot_id>/vote
TOPGG_WEBHOOK_AUTH=              # Long random secret; paste same in Top.gg dashboard webhooks

# Affiliate decorators for /price store URLs
HUMBLE_AFFILIATE=
GMG_AFFILIATE=
FANATICAL_AFFILIATE=
