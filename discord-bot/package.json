{
  "name": "discord-bot",
  "version": "2.0.0",
  "description": "GameGuide-AI Discord bot — production, 24/7-ready",
  "main": "index.js",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "start": "node index.js",
    "register": "node register-commands.js",
    "register:guild": "node register-commands.js",
    "syntax-check": "node --check index.js && node --check register-commands.js",
    "pm2:start": "pm2 start ecosystem.config.js && pm2 save",
    "pm2:stop": "pm2 stop gameguide-bot",
    "pm2:logs": "pm2 logs gameguide-bot",
    "docker:build": "docker build -t gameguide-bot .",
    "docker:run": "docker run --rm --env-file .env -p 3000:3000 gameguide-bot"
  },
  "keywords": [
    "discord",
    "bot",
    "gaming",
    "ai",
    "supabase"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2"
  }
}
